<?xml version="1.0"?>
<ruleset name="icegozi_workflow"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">
    <description>Bộ luật PHPMD thực dụng cho dự án Laravel icegozi_workflow.</description>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/database/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/storage/*</exclude-pattern>
    <exclude-pattern>*/bootstrap/*</exclude-pattern>

    <!-- Phát hiện mã không dùng -->
    <rule ref="rulesets/unusedcode.xml"/>

    <!-- Kích thước / độ phức tạp -->
    <rule ref="rulesets/codesize.xml">
        <exclude name="ExcessiveClassComplexity"/>
    </rule>

    <!-- Thiết kế -->
    <rule ref="rulesets/design.xml">
        <exclude name="CouplingBetweenObjects"/>
        <exclude name="NumberOfChildren"/>
    </rule>

    <!-- Đặt tên: bỏ các luật quá khắt khe với code Laravel -->
    <rule ref="rulesets/naming.xml">
        <exclude name="ShortVariable"/>
        <exclude name="LongVariable"/>
        <exclude name="ShortMethodName"/>
    </rule>

    <!-- Clean code: bỏ các luật xung đột với pattern Laravel (facade, else, cờ boolean) -->
    <rule ref="rulesets/cleancode.xml">
        <exclude name="StaticAccess"/>
        <exclude name="ElseExpression"/>
        <exclude name="BooleanArgumentFlag"/>
        <exclude name="MissingImport"/>
    </rule>
</ruleset>
