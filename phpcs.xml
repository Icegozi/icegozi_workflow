<?xml version="1.0"?>
<ruleset name="icegozi_workflow">
    <description>Chuẩn code PSR-12 cho icegozi_workflow (PHPCS là chuẩn chính).</description>

    <!-- Phạm vi mặc định khi chạy phpcs không kèm tham số file -->
    <file>app</file>
    <file>routes</file>
    <file>config</file>

    <exclude-pattern>*/database/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/storage/*</exclude-pattern>
    <exclude-pattern>*/bootstrap/cache/*</exclude-pattern>

    <arg name="colors"/>
    <arg value="p"/>
    <arg name="extensions" value="php"/>

    <!-- Chỉ ERROR mới làm fail build; WARNING (vd: độ dài dòng PSR-12) không chặn -->
    <config name="ignore_warnings_on_exit" value="1"/>

    <rule ref="PSR12"/>
</ruleset>
